# Forge Solo — user-facing config (set via the Umbrel app config UI).
# Secrets (node RPC, DB, internal token) are generated per-install by exports.sh.

APP_PORT=3080                 # web dashboard port
STRATUM_PORT=3333             # point your miners here
POOL_NAME=Forge Solo
POOL_ADDRESS=                 # REQUIRED: your BCH2 (bitcoincashii:...) payout address — every block's reward is paid here. The stratum refuses to start until this is set.
COINBASE_TAG=Forge            # short label embedded in the coinbase of blocks you mine (<=24 printable chars)
PAYOUT_ADDRESS_1175=          # your 1175 (esf1...) address — REQUIRED for 1175 merge-mining (the aux coinbase pays it directly); merge-mining stays OFF until this is set
MIN_PAYOUT=1                  # minimum balance (BCH2) before an automatic solo payout
